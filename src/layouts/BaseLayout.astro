---
const {
  title = 'Harness Engineering Blog',
  description = 'Harness engineering, agent-ready repositories, AGENTS.md, and repo-level context engineering for coding agents.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.svg" />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #080b12;
        --panel: #101725;
        --panel-2: #151e30;
        --text: #e8eefc;
        --muted: #9dafc9;
        --line: #243149;
        --accent: #79ffe1;
        --accent-2: #9ab6ff;
        --max: 1080px;
      }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: radial-gradient(circle at top left, rgba(121,255,225,.14), transparent 32rem), var(--bg); color: var(--text); line-height: 1.65; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      header, main, footer { width: min(var(--max), calc(100% - 2rem)); margin: 0 auto; }
      header { padding: 1.25rem 0; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
      nav { display: flex; gap: 1rem; flex-wrap: wrap; color: var(--muted); font-size: .95rem; }
      .brand { color: var(--text); font-weight: 800; letter-spacing: -.03em; }
      .hero { padding: 5rem 0 3rem; max-width: 860px; }
      .eyebrow { color: var(--accent); font-weight: 700; text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; }
      h1, h2, h3 { line-height: 1.12; letter-spacing: -.04em; }
      h1 { font-size: clamp(2.6rem, 7vw, 5.8rem); margin: .4rem 0 1rem; }
      h2 { font-size: clamp(1.8rem, 4vw, 3rem); margin-top: 3rem; }
      h3 { font-size: 1.45rem; margin-top: 2rem; }
      p, li { color: var(--muted); }
      strong { color: var(--text); }
      .lead { font-size: clamp(1.1rem, 2vw, 1.35rem); max-width: 760px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; margin: 2rem 0; }
      .card { background: linear-gradient(180deg, var(--panel), rgba(16,23,37,.72)); border: 1px solid var(--line); border-radius: 18px; padding: 1.25rem; }
      .card h3 { margin-top: 0; }
      .button-row { display: flex; gap: .8rem; flex-wrap: wrap; margin-top: 1.6rem; }
      .button { display: inline-flex; align-items: center; border: 1px solid var(--line); border-radius: 999px; padding: .75rem 1rem; background: var(--panel); color: var(--text); font-weight: 700; }
      .button.primary { background: var(--accent); color: #061014; border-color: var(--accent); }
      article { max-width: 820px; padding: 2rem 0 5rem; }
      article h1 { font-size: clamp(2.2rem, 6vw, 4.4rem); }
      article img { max-width: 100%; }
      code { background: var(--panel-2); border: 1px solid var(--line); border-radius: .35rem; padding: .1rem .3rem; color: var(--accent-2); }
      pre { background: #05070d; border: 1px solid var(--line); border-radius: 16px; padding: 1rem; overflow: auto; }
      blockquote { border-left: 3px solid var(--accent); padding-left: 1rem; color: var(--text); }
      footer { border-top: 1px solid var(--line); padding: 2rem 0 4rem; color: var(--muted); }
    </style>
  </head>
  <body>
    <header>
      <a class="brand" href="/">Harness Engineering Blog</a>
      <nav>
        <a href="/agent-ready-repository/">Agent-ready repos</a>
        <a href="/agents-md-template/">AGENTS.md template</a>
        <a href="/blog/">Blog</a>
        <a href="/projects/harness-experimental/">harness-experimental</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      Built for developers turning repositories into reliable workspaces for coding agents.
    </footer>
  </body>
</html>
