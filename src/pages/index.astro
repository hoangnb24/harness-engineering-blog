---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = [
  {
    date: '2026-05-28',
    tags: [
      ['How-to', 'tag-how-to'],
      ['en', 'tag-en'],
    ],
    title: 'How to Write an AGENTS.md That Actually Works',
    image: '/assets/agents-md-context.svg',
    imageClass: 'photo-wide',
    excerpt: 'Most AGENTS.md files nobody reads. Here is how to write one that coding agents actually use — specific, concise, and validated by real sessions.',
    link: '/blog/how-to-write-agents-md/',
  },
  {
    date: '2026-05-24',
    tags: [
      ['Introduction', 'tag-introduction'],
      ['en', 'tag-en'],
    ],
    title: 'What Is an Agent-Ready Repository?',
    image: '/assets/introduction-codeharness.svg',
    imageClass: 'demo-og',
    excerpt: 'An agent-ready repository gives coding agents the instructions, architecture context, validation rules, and decision history they need to make useful, reviewable changes.',
    link: '/agent-ready-repository/',
  },
  {
    date: '2026-05-23',
    tags: [
      ['Document', 'tag-document'],
      ['en', 'tag-en'],
    ],
    title: 'AGENTS.md Template',
    image: '/assets/agents-md-context.svg',
    imageClass: 'demo-og',
    excerpt: 'A practical AGENTS.md template for agent-ready repositories — copy and adapt for Claude Code, Codex, Cursor, and other coding agents.',
    link: '/agents-md-template/',
  },
  {
    date: '2026-05-21',
    tags: [
      ['How-to', 'tag-how-to'],
      ['en', 'tag-en'],
    ],
    title: 'How to make a repository agent-ready',
    image: '/assets/agent-ready-repository.svg',
    imageClass: 'photo-wide',
    excerpt: 'Start with durable instructions, clear scripts, validation loops, and repo context that coding agents can safely follow.',
    link: '/agent-ready-repository/',
  },
  {
    date: '2026-05-20',
    tags: [
      ['Document', 'tag-document'],
      ['en', 'tag-en'],
    ],
    title: 'Supported harness patterns',
    image: '/assets/harness-patterns.svg',
    imageClass: 'demo-og',
    excerpt: 'A working harness combines tests, docs, scripts, conventions, fixtures, examples, and decision records.',
    link: '/projects/harness-experimental/',
  },
  {
    date: '2026-05-19',
    tags: [
      ['Diary', 'tag-diary'],
      ['en', 'tag-en'],
    ],
    title: 'Field notes from shipping with agents',
    image: '/assets/field-notes-agents.svg',
    imageClass: 'photo-medium',
    excerpt: 'Short notes on what worked, what failed, and what should become part of the next CodeHarness iteration.',
    link: '/projects/harness-experimental/',
  },
];
---
<BaseLayout title="CodeHarness" description="Stories, tests, and practical notes from building with AI coding agents.">
  <div slot="site-title">CodeHarness</div>
  <div class="main">
    {posts.map((post) => (
      <article class="post">
        <div class="post-date">{post.date}</div>
        <div class="tags">
          {post.tags.map(([tag, tagClass]) => <a class={`tag ${tagClass}`} href="/blog/">{tag}</a>)}
        </div>
        <h2><a href={post.link}>{post.title}</a></h2>
        <a href={post.link}><img class={post.imageClass} src={post.image} alt="Featured image of the post" loading="lazy" /></a>
        <p>{post.excerpt}</p>
        <a class="read-more" href={post.link}>→ Read more</a>
      </article>
    ))}
    <footer>
      <nav class="pagination" aria-label="Pagination">
        <a href="/"><<</a>
        <a href="/">1</a>
        <a href="/">>></a>
      </nav>
    </footer>
  </div>
</BaseLayout>
