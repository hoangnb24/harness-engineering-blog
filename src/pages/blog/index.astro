---
<BaseLayout title="Blog | Harness Engineering Blog" description="Articles about AGENTS.md, context engineering, and agent-ready repositories.">
  <div slot="site-title">CodeHarness</div>
  <div class="main">
    {blogPosts.map((post) => (
      <article class="post">
        <div class="post-date">{post.date}</div>
        <div class="tags">
          {post.tags.map(([tag, tagClass]) => <a class={`tag ${tagClass}`} href="/blog/">{tag}</a>)}
        </div>
        <h2><a href={post.link}>{post.title}</a></h2>
        <p>{post.excerpt}</p>
        <a class="read-more" href={post.link}>→ Read more</a>
      </article>
    ))}
  </div>
</BaseLayout>
