---
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = [
  {
    date: '2026-05-28',
    tags: [['Introduction', 'tag-introduction'], ['en', 'tag-en']],
    title: 'Coding Agents Need Better Repositories, Not Just Better Prompts',
    excerpt: 'Most coding-agent failures are not model failures. They are repo-context failures. Better prompts help. But repositories need instructions, architecture context, and validation rules.',
    link: '/blog/coding-agents-need-better-repositories/',
  },
  {
    date: '2026-05-28',
    tags: [['Introduction', 'tag-introduction'], ['en', 'tag-en']],
    title: 'Context Engineering for Coding Agents: A Practical Repo-Level Guide',
    excerpt: 'Context engineering for coding agents means shaping the repo environment so agents receive durable, relevant context before they write code. Here is how to apply it.',
    link: '/context-engineering-for-coding-agents/',
  },
  {
    date: '2026-05-28',
    tags: [['How-to', 'tag-how-to'], ['en', 'tag-en']],
    title: 'How to Write an AGENTS.md That Actually Works',
    excerpt: 'Most AGENTS.md files nobody reads. Here is how to write one that coding agents actually use — specific, concise, and validated by real sessions.',
    link: '/blog/how-to-write-agents-md/',
  },
  {
    date: '2026-05-24',
    tags: [['Introduction', 'tag-introduction'], ['en', 'tag-en']],
    title: 'What Is an Agent-Ready Repository?',
    excerpt: 'An agent-ready repository gives coding agents the instructions, architecture context, validation rules, and decision history they need to make useful, reviewable changes.',
    link: '/agent-ready-repository/',
  },
  {
    date: '2026-05-23',
    tags: [['Document', 'tag-document'], ['en', 'tag-en']],
    title: 'AGENTS.md Template',
    excerpt: 'A practical template for agent-ready repositories — copy and adapt for Claude Code, Codex, Cursor, and other coding agents.',
    link: '/agents-md-template/',
  },
  {
    date: '2026-05-20',
    tags: [['Document', 'tag-document'], ['en', 'tag-en']],
    title: 'Supported harness patterns',
    excerpt: 'A working harness combines tests, docs, scripts, conventions, fixtures, examples, and decision records.',
    link: '/projects/harness-experimental/',
  },
];
---
<BaseLayout title="Blog | Harness Engineering Blog" description="Articles about AGENTS.md, context engineering, and agent-ready repositories.">
  <div slot="site-title">CodeHarness</div>
  <div class="main">
    {blogPosts.map((post) => (
      <article class="post">
        <div class="post-date">{post.date}</div>
        <div class="tags">
          {post.tags.map(([tag, tagClass]) => <a class={`tag ${tagClass}`} href="/blog/">{tag}</a>)}
        </div>
        <h2><a href={post.link}>{post.title}</a></h2>
        <p>{post.excerpt}</p>
        <a class="read-more" href={post.link}>→ Read more</a>
      </article>
    ))}
  </div>
</BaseLayout>
